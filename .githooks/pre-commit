#!/usr/bin/env bash
# pre-commit hook: refuse to commit when a plugin's
# .claude-plugin/plugin.json::version disagrees with
# .claude-plugin/marketplace.json's catalog entry.
#
# This is the "drift detector" — the actual version bumps must always go
# through scripts/release-plugin.sh which bumps both files atomically.
#
# Install:  git config core.hooksPath .githooks
# Bypass:   git commit --no-verify   (use sparingly — only when fixing
#           drift you intentionally introduced and will resolve in the
#           same series of commits)
set -euo pipefail

# Pick a working python interpreter — python3 on Linux/macOS, python on Windows.
if command -v python3 >/dev/null 2>&1; then
  py=python3
elif command -v python >/dev/null 2>&1; then
  py=python
else
  echo "pre-commit: no python interpreter found; skipping drift check" >&2
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

marketplace_json=".claude-plugin/marketplace.json"
[ -f "$marketplace_json" ] || exit 0   # not a marketplace repo; nothing to check

# Build name<TAB>version list from marketplace.json.
catalog_entries="$("$py" -c "
import json, sys
data = json.load(open(sys.argv[1]))
for p in data.get('plugins', []):
    print(f\"{p['name']}\t{p['version']}\")
" "$marketplace_json")"

drift=0
while IFS= read -r entry; do
  [ -z "$entry" ] && continue
  name="${entry%%$'\t'*}"
  catalog="${entry##*$'\t'}"
  plugin_json="plugins/${name}/.claude-plugin/plugin.json"
  [ -f "$plugin_json" ] || continue
  source_v="$("$py" -c "import json,sys; print(json.load(open(sys.argv[1]))['version'])" "$plugin_json")"
  if [ "$source_v" != "$catalog" ]; then
    echo "pre-commit: version drift in plugin '${name}':" >&2
    echo "  $plugin_json:      $source_v" >&2
    echo "  $marketplace_json: $catalog"   >&2
    drift=1
  fi
done <<< "$catalog_entries"

if [ "$drift" -ne 0 ]; then
  cat >&2 <<EOF

The two version sources are out of sync. Run:
  scripts/release-plugin.sh <plugin> <patch|minor|major|X.Y.Z>

…to bump them atomically, or fix by hand and stage both files. To bypass
intentionally:  git commit --no-verify
EOF
  exit 1
fi

# Native manifest validation — catches malformed plugin.json, broken skill
# frontmatter, bad hooks/commands wiring. Free safety net via the official
# CLI; we don't have to maintain our own JSON-schema checks.
if command -v claude >/dev/null 2>&1; then
  validation_failed=0
  while IFS= read -r entry; do
    name="${entry%%$'\t'*}"
    plugin_dir="plugins/${name}"
    [ -d "$plugin_dir" ] || continue
    if ! claude plugin validate "$plugin_dir" >/tmp/claude-validate.$$ 2>&1; then
      echo "pre-commit: claude plugin validate failed for $plugin_dir:" >&2
      cat /tmp/claude-validate.$$ >&2
      validation_failed=1
    fi
    rm -f /tmp/claude-validate.$$
  done <<< "$catalog_entries"

  if [ "$validation_failed" -ne 0 ]; then
    cat >&2 <<EOF

Bypass with:  git commit --no-verify
EOF
    exit 1
  fi
fi

exit 0
